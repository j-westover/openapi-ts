{
  "name": "@example/openapi-ts-tanstack-vue-query-redfish",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build-only": "vite build",
    "build": "vue-tsc --build --force && vite build",
    "dev": "vite",
    "dev:fresh": "pkill -f \"$PWD/node_modules/.*vite/bin/vite\\.js\" 2>/dev/null; rm -rf node_modules/.vite && vite",
    "format": "oxfmt src/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "openapi-ts": "openapi-ts",
    "openapi-ts:scoped": "REDFISH_SCOPE=scoped openapi-ts",
    "preview": "vite preview",
    "test:unit": "vitest",
    "typecheck": "vue-tsc --build --force"
  },
  "dependencies": {
    "@tanstack/vue-query": "5.73.3",
    "@tanstack/vue-query-devtools": "5.73.3",
    "axios": "1.9.0",
    "pinia": "3.0.3",
    "vue": "3.5.13",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@hey-api/openapi-ts": "workspace:*",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "27.0.0",
    "@types/node": "24.10.10",
    "@types/pluralize": "0.0.33",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vue/eslint-config-typescript": "14.6.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.8.1",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-plugin-vue": "9.32.0",
    "globals": "15.14.0",
    "jsdom": "28.0.0",
    "oxfmt": "0.27.0",
    "pluralize": "8.0.0",
    "postcss": "8.4.41",
    "tailwindcss": "3.4.9",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.0.2",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.4"
  },
  "//openapi-ts-version": "Active spec is workspace:* because this example lives inside the @hey-api/openapi-ts monorepo. When publishing/releasing this app standalone (npm install outside of pnpm workspaces), swap to a real semver — e.g. \"^0.92.4\"."
}
