{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["vite.config.*", "vitest.config.*", "mock-redfish.ts", "scripts/**/*.ts"],
  // `openapi-ts.config.ts` is the only file kept out of `vue-tsc`: it
  // imports `@hey-api/openapi-ts` directly, and transient type errors
  // in that package's published declarations would otherwise propagate
  // into the production build. The codegen helpers in `scripts/` only
  // depend on `pluralize`, so they are safe to typecheck alongside
  // their unit tests (`scripts/*.spec.ts`).
  "exclude": ["openapi-ts.config.*"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  }
}
